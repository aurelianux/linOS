{
  "name": "berta-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Lightweight system metrics agent for berta (CPU, RAM, GPU)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "PORT=4002 tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
