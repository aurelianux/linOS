# linBoard API — Environment Variables
# Copy this file to .env and fill in the values.
# In production, these are sourced from .env.linos at the repo root.

# Server
NODE_ENV=development
PORT=4001
LOG_LEVEL=info

# CORS — comma-separated allowed origins
CORS_ALLOW_ORIGINS=http://localhost:4000,http://dashboard.lan

# Dashboard hostname
LINOS_DASHBOARD_HOST=dashboard.lan

# Optional: path to services monitoring config (health probes)
# Defaults to config/services.json at the repo root
# SERVICES_CONFIG_PATH=

# Optional: path to dashboard entity config (rooms, entities, quick toggles)
# Defaults to config/dashboard.json at the repo root
# DASHBOARD_CONFIG_PATH=

# Optional: Home Assistant (for server-side features like timer light feedback)
# LINOS_HA_URL=http://<YOUR_HA_HOST>:8123
# LINOS_HA_TOKEN=<YOUR_HA_TOKEN>

# Optional: comma-separated light entity IDs for notification feedback
# LINOS_NOTIFICATION_LIGHT_ENTITIES=light.hallway,light.desk

# Optional: SSH target for /admin/git-pull
# If unset, the endpoint returns a config error.
# LINOS_GIT_PULL_SSH_HOST=<YOUR_HOST_IP>
# LINOS_GIT_PULL_SSH_PORT=22
# LINOS_GIT_PULL_SSH_USER=<your-user>
# LINOS_GIT_PULL_SSH_PRIVATE_KEY_PATH=/run/secrets/linos_git_pull_key
# LINOS_GIT_PULL_SSH_PRIVATE_KEY_PASSPHRASE=
# LINOS_GIT_PULL_REMOTE_REPO_PATH=/home/<your-user>/linOS
