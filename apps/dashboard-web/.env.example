# linBoard Frontend — Environment Variables
# Copy this file to .env and fill in the values.
# In production, these are set via build args in docker-compose.

# Home Assistant WebSocket URL (accessed from the browser)
VITE_HA_URL=http://<YOUR_HA_HOST>:8123

# Home Assistant Long-Lived Access Token
VITE_HA_TOKEN=<YOUR_HA_TOKEN>

# API base path (default: /api — proxied via Vite in dev, Caddy in prod)
VITE_API_BASE=/api
