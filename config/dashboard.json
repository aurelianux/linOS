{
  "rooms": [
    {
      "id": "wohnzimmer",
      "name": "Living Room",
      "icon": "mdiSofa",
      "entities": [
        "light.bidschirm",
        "light.links",
        "light.rechts",
        "light.notenschlussel",
        "media_player.fernseher",
        "media_player.arbeitszimmer",
        "climate.thermostat_wz"
      ],
      "airQuality": {
        "temperature": "sensor.lufsensor_wz_temperature",
        "humidity": "sensor.lufsensor_wz_humidity",
        "secondary": [
          "sensor.lufsensor_wz_pressure",
          "sensor.lufsensor_wz_battery",
          "sensor.lufsensor_wz_voltage"
        ]
      }
    },
    {
      "id": "kueche",
      "name": "Kitchen",
      "icon": "mdiKitchen",
      "entities": [
        "light.kuche"
      ]
    },
    {
      "id": "schlafzimmer",
      "name": "Bedroom",
      "icon": "mdiBed",
      "entities": [
        "light.nachttisch"
      ]
    },
    {
      "id": "flur",
      "name": "Hallway",
      "icon": "mdiHomeVariant",
      "entities": [
        "light.flur"
      ]
    },
    {
      "id": "badezimmer",
      "name": "Bathroom",
      "icon": "mdiShower",
      "entities": [
        "climate.thermostat_bad"
      ],
      "airQuality": {
        "temperature": "sensor.luftsensor_bad_temperature",
        "humidity": "sensor.luftsensor_bad_humidity",
        "secondary": [
          "sensor.luftsensor_bad_pressure",
          "sensor.luftsensor_bad_battery",
          "sensor.luftsensor_bad_voltage"
        ]
      }
    }
  ],
  "lightColorPresets": [
    { "id": "warmweiss", "label": "Warm",    "displayColor": "#f5a623", "colorTemp": 370 },
    { "id": "neutral",   "label": "Neutral", "displayColor": "#f0e6d0", "colorTemp": 250 },
    { "id": "kaltweiss", "label": "Cool",    "displayColor": "#cce5ff", "colorTemp": 153 },
    { "id": "orange",    "label": "Orange",  "displayColor": "#ff8c00", "hsColor": [30, 90] },
    { "id": "blau",      "label": "Blue",    "displayColor": "#5b9bd5", "hsColor": [220, 60] }
  ],
  "quickToggles": {
    "modes": ["hell", "chill", "aus"],
    "rooms": [
      {
        "roomId": "wohnzimmer",
        "modeConfig": {
          "hell": {
            "light.bidschirm":      { "state": "on", "brightness": 255, "color_temp": 370 },
            "light.links":          { "state": "on", "brightness": 255, "color_temp": 370 },
            "light.rechts":         { "state": "on", "brightness": 255, "color_temp": 370 },
            "light.notenschlussel": { "state": "on", "brightness": 255, "color_temp": 370 }
          },
          "chill": {
            "light.bidschirm":      { "state": "on", "brightness": 30, "color_temp": 500 },
            "light.links":          { "state": "on", "brightness": 30, "color_temp": 500 },
            "light.rechts":         { "state": "on", "brightness": 30, "color_temp": 500 },
            "light.notenschlussel": { "state": "on", "brightness": 70, "color_temp": 370 }
          },
          "dunkel": {
            "light.bidschirm":      { "state": "on", "brightness": 3, "color_temp": 500 },
            "light.links":          { "state": "off" },
            "light.rechts":         { "state": "on", "brightness": 3, "color_temp": 500 },
            "light.notenschlussel": { "state": "off" }
          },
          "aus": {
            "light.bidschirm":      { "state": "off" },
            "light.links":          { "state": "off" },
            "light.rechts":         { "state": "off" },
            "light.notenschlussel": { "state": "off" }
          }
        }
      },
      {
        "roomId": "kueche",
        "modeConfig": {
          "hell":  { "light.kuche": { "state": "on",  "brightness": 255, "color_temp": 250 } },
          "chill": { "light.kuche": { "state": "on",  "brightness": 80,  "color_temp": 370 } },
          "dunkel": { "light.kuche": { "state": "on",  "brightness": 2,  "color_temp": 370 } },
          "aus":   { "light.kuche": { "state": "off" } }
        }
      },
      {
        "roomId": "schlafzimmer",
        "modeConfig": {
          "hell":  { "light.nachttisch": { "state": "on",  "brightness": 255, "color_temp": 370 } },
          "chill": { "light.nachttisch": { "state": "on",  "brightness": 40,  "color_temp": 500 } },
          "dunkel": { "light.nachttisch": { "state": "on",  "brightness": 6,  "color_temp": 500 } },
          "aus":   { "light.nachttisch": { "state": "off" } }
        }
      },
      {
        "roomId": "flur",
        "modeConfig": {
          "hell":  { "light.flur": { "state": "on",  "brightness": 255, "color_temp": 250 } },
          "chill": { "light.flur": { "state": "on",  "brightness": 60,  "color_temp": 370 } },
          "dunkel": { "light.flur": { "state": "on",  "brightness": 2,  "color_temp": 370 } },
          "aus":   { "light.flur": { "state": "off" } }
        }
      }
    ]
  },
  "adminStacks": [
    { "projectName": "dashboard",     "label": "Dashboard",               "composePath": "stacks/applications/dashboard" },
    { "projectName": "homeassistant", "label": "Home Assistant",          "composePath": "stacks/homeassistant" },
    { "projectName": "zigbee2mqtt",   "label": "Zigbee2MQTT",             "composePath": "stacks/zigbee2mqtt" },
    { "projectName": "infra",         "label": "Infra (Node-RED + MQTT)", "composePath": "stacks/infra" },
    { "projectName": "dns",           "label": "AdGuard Home",            "composePath": "stacks/dns" },
    { "projectName": "proxy",         "label": "Caddy",                   "composePath": "stacks/proxy" },
    { "projectName": "service-index", "label": "Service Index",           "composePath": "stacks/applications/service-index" },
    { "projectName": "plane-app",     "label": "Plane",                   "composePath": "stacks/applications/plane/plane-app" }
  ],
  "motionSensors": [
    {
      "id": "flur",
      "entityId": "binary_sensor.bewegungsmelder_flur_occupancy"
    }
  ],
  "roborock": {
    "entityId": "vacuum.s7_max_ultra",
    "segments": [
      { "id": 16, "roomId": "kueche",       "defaultSelected": false },
      { "id": 17, "roomId": "flur",         "defaultSelected": true  },
      { "id": 18, "roomId": "schlafzimmer", "defaultSelected": false },
      { "id": 19, "roomId": "badezimmer",   "defaultSelected": false },
      { "id": 20, "roomId": "wohnzimmer",   "defaultSelected": true  }
    ],
    "defaultFanPower": 103,
    "defaultWaterBoxMode": 203,
    "defaultCleaningMode": "vacuum_and_mop"
  },
  "vacuum": {
    "returnToDockOnPause": true,
    "routines": [
      {
        "id": "quick-clean",
        "label": "Quick Clean",
        "description": "Vacuum flur & küche",
        "steps": [
          {
            "mode": "vacuum",
            "segments": ["flur", "kueche"],
            "fanPower": 206,
            "waterBoxMode": null
          }
        ]
      },
      {
        "id": "deep-clean",
        "label": "Deep Clean",
        "description": "Full vacuum → mop → final vacuum",
        "steps": [
          {
            "mode": "vacuum_and_mop",
            "segments": ["flur", "kueche", "wohnzimmer", "schlafzimmer", "badezimmer"],
            "fanPower": 206,
            "waterBoxMode": 203
          },
          {
            "mode": "vacuum_and_mop",
            "segments": ["flur", "kueche", "wohnzimmer"],
            "fanPower": 103,
            "waterBoxMode": 203
          },
          {
            "mode": "vacuum_and_mop",
            "segments": ["flur", "kueche", "wohnzimmer", "schlafzimmer", "badezimmer"],
            "fanPower": 0,
            "waterBoxMode": 203
          }
        ]
      }
    ]
  }
}
