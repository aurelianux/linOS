  "lightColorPresets": [
    { "id": "warmweiss", "label": "Warm", "displayColor": "#f5a623", "colorTemp": 370 },
    { "id": "neutral", "label": "Neutral", "displayColor": "#f0e6d0", "colorTemp": 250 },
    { "id": "kaltweiss", "label": "Cool", "displayColor": "#cce5ff", "colorTemp": 153 },
    { "id": "orange", "label": "Orange", "displayColor": "#ff8c00", "hsColor": [30, 90] },
    { "id": "blau", "label": "Blue", "displayColor": "#5b9bd5", "hsColor": [220, 60] }
  ],
  "quickToggles": {
    "globalEntity": "input_select.lighting_mode",
    "modes": ["hell", "chill", "aus"],
    "rooms": [
      { "roomId": "wohnzimmer", "entity": "input_select.lighting_mode_wohnzimmer" },
      { "roomId": "kueche", "entity": "input_select.lighting_mode_kueche" },
      { "roomId": "schlafzimmer", "entity": "input_select.lighting_mode_schlafzimmer" },
      { "roomId": "flur", "entity": "input_select.lighting_mode_flur" }
    ]
  },
  "adminStacks": [
    { "projectName": "dashboard",     "label": "Dashboard",               "composePath": "stacks/applications/dashboard" },
    { "projectName": "homeassistant", "label": "Home Assistant",          "composePath": "stacks/homeassistant" },
    { "projectName": "zigbee2mqtt",   "label": "Zigbee2MQTT",             "composePath": "stacks/zigbee2mqtt" },
    { "projectName": "infra",         "label": "Infra (Node-RED + MQTT)", "composePath": "stacks/infra" },
    { "projectName": "dns",           "label": "AdGuard Home",            "composePath": "stacks/dns" },
    { "projectName": "proxy",         "label": "Caddy",                   "composePath": "stacks/proxy" },
    { "projectName": "service-index", "label": "Service Index",           "composePath": "stacks/applications/service-index" },
    { "projectName": "plane-app",     "label": "Plane",                   "composePath": "stacks/applications/plane/plane-app" }
  ],
  "roborock": {
    "entityId": "vacuum.s7_max_ultra",
    "segments": [
      { "id": 16, "roomId": "kueche", "defaultSelected": false },
      { "id": 17, "roomId": "flur", "defaultSelected": true },
      { "id": 18, "roomId": "schlafzimmer", "defaultSelected": false },
      { "id": 19, "roomId": "badezimmer", "defaultSelected": false },
      { "id": 20, "roomId": "wohnzimmer", "defaultSelected": true }
    ],
    "defaultFanPower": 103,
    "defaultWaterBoxMode": 203,
    "defaultCleaningMode": "vacuum_and_mop"
  },
  "vacuum": {
    "returnToDockOnPause": true,
    "routines": [
      {
        "id": "quick-clean",
        "label": "Quick Clean",
        "description": "Vacuum flur & küche",
        "steps": [
          {
            "mode": "vacuum",
            "segments": ["flur", "kueche"],
            "fanPower": 206,
            "waterBoxMode": null
          }
        ]
      },
      {
        "id": "deep-clean",
        "label": "Deep Clean",
        "description": "Full vacuum → mop → final vacuum",
        "steps": [
          {
            "mode": "vacuum",
            "segments": ["flur", "kueche", "wohnzimmer"],
            "fanPower": 206,
            "waterBoxMode": null
          },
          {
            "mode": "vacuum_and_mop",
            "segments": ["flur", "kueche", "wohnzimmer"],
            "fanPower": 103,
            "waterBoxMode": 203
          },
          {
            "mode": "vacuum",
            "segments": ["flur", "kueche", "wohnzimmer", "schlafzimmer", "badezimmer"],
            "fanPower": 103,
            "waterBoxMode": null
          }
        ]
      }
    ]
  }
}
