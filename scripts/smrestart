#!/usr/bin/env bash
# smrestart – Restart all linOS Docker Compose stacks.
#
# Reads stack definitions from config/manny-shell.json.
# Logs are written to logs/smrestart_<timestamp>.log.
#
# Usage:
#   ./scripts/smrestart
#
# The script can be run from any directory.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CONFIG="$REPO_ROOT/config/manny-shell.json"
LOGS_DIR="$REPO_ROOT/logs"
TS=$(date +%Y%m%d_%H%M%S)
LOGFILE="$LOGS_DIR/smrestart_${TS}.log"

mkdir -p "$LOGS_DIR"

_smstatus() {
    echo "=== linOS Container Status @ $(date) ==="
    docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' 2>/dev/null || true
}

_run() {
    echo "=== smrestart @ $(date) ==="
    echo ""

    echo "=== linOS Stacks ==="
    python3 - "$CONFIG" <<'PYEOF'
import json, sys
with open(sys.argv[1]) as f:
    data = json.load(f)
for s in data["stacks"]:
    print(f"{s['name']:<14} {s['path']:<50} {s['label']}")
PYEOF

    echo ""
    echo "--- docker compose up -d ---"
    echo ""

    python3 - "$CONFIG" "$REPO_ROOT" <<'PYEOF'
import json, os, subprocess, sys
with open(sys.argv[1]) as f:
    data = json.load(f)
repo = sys.argv[2]
errors = []
for s in data["stacks"]:
    name, label, path = s["name"], s["label"], os.path.join(repo, s["path"])
    print(f"### {name} – {label}")
    print(f"→ {path}")
    r = subprocess.run(["docker", "compose", "up", "-d"], cwd=path, capture_output=True, text=True)
    if r.stdout:
        print(r.stdout, end="")
    if r.stderr:
        print(r.stderr, end="")
    if r.returncode != 0:
        errors.append(name)
    print()
if errors:
    print(f"ERROR: failed stacks: {', '.join(errors)}", flush=True)
    sys.exit(1)
PYEOF

    echo "--- Status after Restart ---"
    _smstatus
}

_run 2>&1 | tee "$LOGFILE"

echo ""
echo "✔ Log: $LOGFILE"
