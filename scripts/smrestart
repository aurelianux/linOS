#!/usr/bin/env bash
# smrestart – Restart all linOS Docker Compose stacks.
#
# Reads stack definitions from config/services.json (stackPath field).
# Logs are written to logs/smrestart_<timestamp>.log.
#
# Usage:
#   ./scripts/smrestart
#
# The script can be run from any directory.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CONFIG="$REPO_ROOT/config/services.json"
LOGS_DIR="$REPO_ROOT/logs"
TS=$(date +%Y%m%d_%H%M%S)
LOGFILE="$LOGS_DIR/smrestart_${TS}.log"

mkdir -p "$LOGS_DIR"

_smstatus() {
    echo "=== linOS Container Status @ $(date) ==="
    docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' 2>/dev/null || true
}

_run() {
    echo "=== smrestart @ $(date) ==="
    echo ""

    echo "=== linOS Stacks ==="
    python3 - "$CONFIG" <<'PYEOF'
import json, os, sys
with open(sys.argv[1]) as f:
    data = json.load(f)
seen = {}
for s in data["services"]:
    sp = s.get("stackPath")
    if not sp:
        continue
    if sp not in seen:
        seen[sp] = []
    seen[sp].append(s["label"])
for path, labels in seen.items():
    name = os.path.basename(path.rstrip("/"))
    print(f"{name:<20} {path:<55} {', '.join(labels)}")
PYEOF

    echo ""
    echo "--- docker compose up -d ---"
    echo ""

    python3 - "$CONFIG" "$REPO_ROOT" <<'PYEOF'
import json, os, subprocess, sys

def collect_stacks(services):
    """Return ordered dict of stackPath -> list of service labels."""
    seen = {}
    for s in services:
        sp = s.get("stackPath")
        if not sp:
            continue
        if sp not in seen:
            seen[sp] = []
        seen[sp].append(s["label"])
    return seen

with open(sys.argv[1]) as f:
    data = json.load(f)
repo = sys.argv[2]
stacks = collect_stacks(data["services"])
errors = []
for path, labels in stacks.items():
    name = os.path.basename(path.rstrip("/"))
    full_path = os.path.join(repo, path)
    print(f"### {name} – {', '.join(labels)}")
    print(f"→ {full_path}")
    r = subprocess.run(["docker", "compose", "up", "-d"], cwd=full_path, capture_output=True, text=True)
    if r.stdout:
        print(r.stdout, end="")
    if r.stderr:
        print(r.stderr, end="")
    if r.returncode != 0:
        errors.append(name)
    print()
if errors:
    print(f"ERROR: failed stacks: {', '.join(errors)}", flush=True)
    sys.exit(1)
PYEOF

    echo "--- Status after Restart ---"
    _smstatus
}

_run 2>&1 | tee "$LOGFILE"

echo ""
echo "✔ Log: $LOGFILE"
