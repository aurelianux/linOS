#!/usr/bin/env bash
# smrestart – Restart linOS Docker Compose stacks.
#
# Reads stack definitions from config/services.json (stackPath + host fields).
# Each service's "host" field selects the Docker context used to run compose:
#   "manny" (or absent/empty) → default Docker context (wherever the script runs)
#   any other value           → docker --context <name> compose ...
# Logs are written to logs/smrestart_<timestamp>.log.
#
# Usage:
#   ./scripts/smrestart [--host <name>]
#
#   --host <name>   Only restart stacks assigned to this host. If omitted,
#                   all stacks are restarted. Stacks are matched by the "host"
#                   field in services.json; "manny" matches the default host.
#
# The script can be run from any directory.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CONFIG="$REPO_ROOT/config/services.json"
LOGS_DIR="$REPO_ROOT/logs"
TS=$(date +%Y%m%d_%H%M%S)
LOGFILE="$LOGS_DIR/smrestart_${TS}.log"

HOST_FILTER=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      if [[ -z "${2:-}" ]]; then
        echo "ERROR: --host requires an argument" >&2
        exit 1
      fi
      HOST_FILTER="$2"
      shift 2
      ;;
    *)
      echo "ERROR: Unknown argument: $1" >&2
      echo "Usage: $0 [--host <name>]" >&2
      exit 1
      ;;
  esac
done

mkdir -p "$LOGS_DIR"

_smstatus() {
    echo "=== linOS Container Status @ $(date) ==="
    docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' 2>/dev/null || true
}

_run() {
    echo "=== smrestart @ $(date) ==="
    echo ""

    echo "=== linOS Stacks ==="
    python3 - "$CONFIG" "$HOST_FILTER" <<'PYEOF'
import json, os, sys

def normalize_host(h):
    return (h or "").strip() or "manny"

with open(sys.argv[1]) as f:
    data = json.load(f)
host_filter = sys.argv[2] if len(sys.argv) > 2 else ""

seen = {}
for s in data["services"]:
    sp = s.get("stackPath")
    if not sp:
        continue
    host = normalize_host(s.get("host", ""))
    if host_filter and host != host_filter:
        continue
    if sp not in seen:
        seen[sp] = {"host": host, "labels": []}
    seen[sp]["labels"].append(s["label"])

if not seen:
    if host_filter:
        print(f"  (no stacks found for host '{host_filter}')")
    else:
        print("  (no stacks found)")
else:
    for path, info in seen.items():
        name = os.path.basename(path.rstrip("/"))
        print(f"{name:<20} {path:<55} [{info['host']}]  {', '.join(info['labels'])}")
PYEOF

    echo ""
    echo "--- docker compose up -d ---"
    echo ""

    python3 - "$CONFIG" "$REPO_ROOT" "$HOST_FILTER" <<'PYEOF'
import json, os, subprocess, sys

def normalize_host(h):
    return (h or "").strip() or "manny"

def context_args(host):
    """Return extra docker CLI args to target a non-default host context."""
    if host == "manny":
        return []
    return ["--context", host]

config_path = sys.argv[1]
repo = sys.argv[2]
host_filter = sys.argv[3] if len(sys.argv) > 3 else ""

with open(config_path) as f:
    data = json.load(f)

# Build ordered stack map: stackPath -> {host, labels}
stacks = {}
for s in data["services"]:
    sp = s.get("stackPath")
    if not sp:
        continue
    host = normalize_host(s.get("host", ""))
    if host_filter and host != host_filter:
        continue
    if sp not in stacks:
        stacks[sp] = {"host": host, "labels": []}
    elif stacks[sp]["host"] != host:
        print(
            f"WARNING: stack '{sp}' has conflicting host values "
            f"('{stacks[sp]['host']}' vs '{host}') — using first value",
            file=sys.stderr,
        )
    stacks[sp]["labels"].append(s["label"])

if not stacks:
    if host_filter:
        print(f"No stacks found for host '{host_filter}'. Nothing to do.")
    else:
        print("No stacks found. Nothing to do.")
    sys.exit(0)

# Validate Docker contexts up front — fail before touching anything
needed_contexts = sorted({info["host"] for info in stacks.values() if info["host"] != "manny"})
missing = []
for ctx in needed_contexts:
    r = subprocess.run(["docker", "context", "inspect", ctx], capture_output=True)
    if r.returncode != 0:
        missing.append(ctx)
if missing:
    for ctx in missing:
        print(f"ERROR: Docker context '{ctx}' not found.", file=sys.stderr)
        print(
            f"       Create it with:  "
            f"docker context create {ctx} --docker \"host=ssh://user@<ip>\"",
            file=sys.stderr,
        )
    sys.exit(1)

errors = []
for path, info in stacks.items():
    host = info["host"]
    name = os.path.basename(path.rstrip("/"))
    full_path = os.path.join(repo, path)
    print(f"### {name} [{host}] – {', '.join(info['labels'])}")
    print(f"→ {full_path}")
    cmd = ["docker"] + context_args(host) + ["compose", "up", "-d"]
    r = subprocess.run(cmd, cwd=full_path, capture_output=True, text=True)
    if r.stdout:
        print(r.stdout, end="")
    if r.stderr:
        print(r.stderr, end="")
    if r.returncode != 0:
        errors.append(name)
    print()

if errors:
    print(f"ERROR: failed stacks: {', '.join(errors)}", flush=True)
    sys.exit(1)
PYEOF

    echo "--- Status after Restart ---"
    _smstatus
}

_run 2>&1 | tee "$LOGFILE"

echo ""
echo "✔ Log: $LOGFILE"
