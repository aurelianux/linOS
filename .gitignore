# Home Assistant runtime/state
stacks/homeassistant/config/.storage/
stacks/homeassistant/config/home-assistant.log*
stacks/homeassistant/config/.shopping_list.json
stacks/homeassistant/config/zigbee.db
stacks/homeassistant/config/androidtv_remote_*.pem
stacks/homeassistant/config/custom_components/

# HA Database & Locks
stacks/homeassistant/config/home-assistant_v2.db*
stacks/homeassistant/config/.HA_VERSION
stacks/homeassistant/config/.ha_run.lock
stacks/homeassistant/config/backups/
stacks/homeassistant/config/tts/
stacks/homeassistant/config/deps/
stacks/homeassistant/config/secrets.yaml

# Mosquitto runtime data
stacks/infra/mosquitto/data/
stacks/infra/mosquitto/log/

# Node-RED runtime files
stacks/infra/nodered/.config.*.json
stacks/infra/nodered/node_modules/
stacks/infra/nodered/flows_cred.json
stacks/infra/nodered/*.backup

# Caddy runtime & TLS certificates
stacks/proxy/data/
stacks/proxy/config/caddy/

# AdGuard Home runtime & configuration backups
stacks/dns/work/
stacks/dns/conf/AdGuardHome.yaml*

# Zigbee2MQTT runtime & device database
stacks/zigbee2mqtt/data/

# Plane app secrets & logs
stacks/applications/plane/plane-app/.env
stacks/applications/plane/plane-app/plane.env
stacks/applications/plane/plane-app/plane-debug.log

# Dashboard dependencies
apps/node_modules/
apps/*/node_modules/
apps/*/dist/

# Accidental debug output from watch(1)
stacks/watch_*

# Environment variables (use .env.linos at root for all services)
.env
.env.local
.env.linos
