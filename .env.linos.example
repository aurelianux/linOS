# linOS – Beispiel-Konfiguration
# Kopiere diese Datei nach .env.linos und ersetze alle <PLACEHOLDER>-Werte.
# .env.linos wird NICHT versioniert (siehe .gitignore).

# ──────────────────────────────────────────────────────────
# Host / Basis
# ──────────────────────────────────────────────────────────
# Primary host (Manny). This is the default target for any stack
# that has no explicit "host" field in config/services.json.
LINOS_HOST_IP=<HOST_IP>          # e.g. 192.168.1.10

# ──────────────────────────────────────────────────────────
# Multi-Host Support (Thunderhead)
# Additional hosts follow the naming convention:
#   LINOS_HOST_<UPPERCASE_NAME>_IP=<IP>
# Each name maps to a Docker context of the same lowercase name.
# Create a context with:
#   docker context create <name> --docker "host=ssh://user@<ip>"
# ──────────────────────────────────────────────────────────
LINOS_HOST_BERTA_IP=<BERTA_IP>      # e.g. 192.168.2.32 (Berta, NVIDIA GPU)

TZ=Europe/Berlin

# ──────────────────────────────────────────────────────────
# Proxy-Ports (auf dem Host)
# ──────────────────────────────────────────────────────────
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443

# ──────────────────────────────────────────────────────────
# Service-Ports (Host-Seite)
# ──────────────────────────────────────────────────────────
DNS_WEB_PORT=3000        # AdGuard Web UI
HA_PORT=8123             # Home Assistant (host network)
MQTT_PORT=1883           # MQTT (Mosquitto)
MQTT_WS_PORT=9001        # MQTT WebSocket
NODE_RED_PORT=1880       # Node-RED
Z2M_WEB_PORT=8082        # Zigbee2MQTT Web UI
SERVICE_INDEX_PORT=8081  # Service-Index Landingpage
PLANE_PROXY_PORT=8080    # Plane-Proxy (Frontend)
DASHBOARD_WEB_PORT=4000  # Dashboard Web
DASHBOARD_API_PORT=4001  # Dashboard API
WYOMING_WHISPER_PORT=10300  # Wyoming Whisper STT (Wyoming protocol; moves to Berta, later milestone)
WYOMING_PIPER_PORT=10200    # Wyoming Piper TTS (Wyoming protocol; moves to Berta, later milestone)

# ──────────────────────────────────────────────────────────
# Domains / Hostnamen
# ──────────────────────────────────────────────────────────
LINOS_DOMAIN_BASE=lan
LINOS_MAIN_DOMAIN=<HOSTNAME>.lan          # e.g. home.lan

LINOS_HA_HOST=ha.<HOSTNAME>.lan
LINOS_DNS_HOST=dns.<HOSTNAME>.lan
LINOS_PLANE_HOST=plane.<HOSTNAME>.lan
LINOS_FLOW_HOST=flow.<HOSTNAME>.lan
LINOS_Z2M_HOST=z2m.<HOSTNAME>.lan
LINOS_SERVICE_INDEX_HOST=<HOSTNAME>.lan
LINOS_DASHBOARD_HOST=dashboard.lan

# ──────────────────────────────────────────────────────────
# Dashboard Frontend (Vite)
# ──────────────────────────────────────────────────────────
VITE_HA_URL=http://homeassistant.local:8123    # Home Assistant URL (WebSocket vom Browser)
VITE_HA_TOKEN=<SECRET>                          # HA Long-Lived Access Token

# ──────────────────────────────────────────────────────────
# Dashboard API – Stack Monitoring
# ──────────────────────────────────────────────────────────
# Path to the services monitoring config (healthcheck probes).
# The file lists which stacks to probe and their health URLs.
# Default (dev): config/services.json at the repo root.
# Production example: absolute path or Docker volume mount.
SERVICES_CONFIG_PATH=<PATH_TO_CONFIG>/config/services.json

# ──────────────────────────────────────────────────────────
# Tailscale  –  Schlüssel aus dem Tailscale Admin UI holen:
#   https://login.tailscale.com/admin/settings/keys
# ──────────────────────────────────────────────────────────
TS_AUTHKEY=<SECRET>
TS_HOSTNAME=<TS_HOSTNAME>            # e.g. homelab
TS_ADVERTISE_ROUTES=<LAN_CIDR>       # e.g. 192.168.1.0/24

# ──────────────────────────────────────────────────────────
# Dashboard API – Home Assistant (for server-side features)
# ──────────────────────────────────────────────────────────
LINOS_HA_URL=http://homeassistant.local:8123     # HA REST API URL (server-side)
LINOS_HA_TOKEN=<SECRET>                           # HA Long-Lived Access Token

# ──────────────────────────────────────────────────────────
# Dashboard API – Light Notification
# ──────────────────────────────────────────────────────────
# Comma-separated HA light entity IDs used as notification lights.
# Used by timer (progress/alert) and future notification features.
# Leave empty to disable light feedback.
LINOS_NOTIFICATION_LIGHT_ENTITIES=light.hallway,light.kitchen

# ────────────────────────────────────────────────────────
# Docker
# ────────────────────────────────────────────────────────
DOCKER_GID=968

# ──────────────────────────────────────────────────────────
# Dashboard API – Git-Pull SSH key (optional)
# ──────────────────────────────────────────────────────────
# Absolute host path to the SSH private key mounted into the
# dashboard-api container at /run/secrets/linos_git_pull_key.
# Used by the /admin/git-pull endpoint. Leave unset to disable.
# Example: /home/<your-user>/.ssh/linos_git_pull
LINOS_GIT_PULL_SSH_PRIVATE_KEY_HOST_PATH=
